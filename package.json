{
  "name": "modelbound-cursor-plugin",
  "version": "0.3.3",
  "description": "Official ModelBound plugin for Cursor — slash commands for skill pipeline, trust & safety, versions, and MCP-backed context sync.",
  "license": "MIT",
  "repository": "https://github.com/ModelBound/cursor-plugin",
  "homepage": "https://modelbound.co/connect",
  "keywords": [
    "modelbound",
    "cursor",
    "cursor-plugin",
    "agent-skills",
    "context-engineering",
    "prompt-engineering",
    "mcp",
    "model-context-protocol",
    "skill-pipeline",
    "token-optimization",
    "ai-agents",
    "vscode"
  ],
  "bin": {
    "modelbound-cursor-install": "./scripts/install.mjs"
  },
  "scripts": {
    "install-plugin": "node scripts/install.mjs",
    "hook": "node scripts/pre-skill-write.mjs",
    "prepublishOnly": "node -e \"require('fs').accessSync('.cursor-plugin/plugin.json')\""
  },
  "engines": { "node": ">=20" },
  "files": [
    ".cursor",
    ".cursor-plugin",
    "commands",
    "hooks",
    "skills",
    "rules",
    "assets",
    "mcp.json",
    "scripts",
    "README.md",
    "LICENSE"
  ]
}
